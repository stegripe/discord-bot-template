{
    "name": "discord-bot-template",
    "version": "1.0.0",
    "description": "A template for Stegripe Discord bot projects.",
    "license": "AGPL-3.0",
    "author": "Stegripe Development <support@stegripe.org>",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/stegripe/discord-bot-template.git"
    },
    "bugs": {
        "url": "https://github.com/stegripe/discord-bot-template/issues"
    },
    "homepage": "https://github.com/stegripe/discord-bot-template#readme",
    "main": "dist/index.js",
    "type": "module",
    "scripts": {
        "build": "pnpm lint && rimraf dist && tsc --build tsconfig.json",
        "lint": "biome check .",
        "lint:fix": "biome check --write .",
        "start": "node -r dotenv/config . | pino-pretty -t \"SYS:yyyy-MM-dd HH:mm:ss\"",
        "dev": "pnpm build && pnpm start"
    },
    "engines": {
        "node": ">=20.0.0",
        "npm": ">=7.0.0"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.4.10",
        "@stegripe/biomejs-config": "^1.1.0",
        "@types/node": "^24.12.2",
        "rimraf": "^6.1.3",
        "typescript": "^5.9.3"
    },
    "dependencies": {
        "@sapphire/decorators": "^6.2.0",
        "@sapphire/framework": "^5.5.0",
        "@stegripe/command-context": "^1.2.0",
        "@stegripe/pino-logger": "^1.2.0",
        "date-fns": "^4.1.0",
        "discord.js": "^14.26.2",
        "dotenv": "^17.4.0",
        "pino": "^10.3.1",
        "pino-pretty": "^13.1.3",
        "tree-kill": "^1.2.2",
        "tslib": "^2.8.1"
    }
}
